# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OpenAI API Key
OPENAI_API_KEY=sk-your_openai_api_key

# App URL (set to your production domain in prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Polar.sh (https://polar.sh) — billing & subscriptions
# Organization Access Token: Polar Dashboard → Settings → Developers → New Token
POLAR_ACCESS_TOKEN=polar_oat_your_access_token
# 'sandbox' for testing (sandbox.polar.sh), 'production' when live
POLAR_SERVER=sandbox
# Webhook signing secret: Polar Dashboard → Settings → Webhooks → your endpoint
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret
# Product IDs from Polar Dashboard → Products → copy the product ID (uuid)
POLAR_PRO_PRODUCT_ID=your_pro_product_id
POLAR_MAX_PRODUCT_ID=your_max_product_id

# Resend (https://resend.com) — transactional + digest emails
RESEND_API_KEY=your_resend_api_key

# Cron secret — protects /api/cron (Vercel Cron sends it as a Bearer token)
CRON_SECRET=generate_a_long_random_string
