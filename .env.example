# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OpenAI API Key
OPENAI_API_KEY=sk-your_openai_api_key

# App URL (set to your production domain in prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Polar.sh (https://polar.sh) — billing & subscriptions
# ── ONE switch toggles test ↔ real billing ──
#   sandbox    = test cards (4242 4242 4242 4242), NO real charges
#   production = real money
POLAR_SERVER=sandbox

# Sandbox credentials (from sandbox.polar.sh) — used when POLAR_SERVER=sandbox
POLAR_SANDBOX_ACCESS_TOKEN=polar_oat_sandbox_token
POLAR_SANDBOX_WEBHOOK_SECRET=polar_whs_sandbox_secret
POLAR_SANDBOX_PRO_PRODUCT_ID=sandbox_pro_product_uuid
POLAR_SANDBOX_MAX_PRODUCT_ID=sandbox_max_product_uuid

# Production credentials (from polar.sh) — used when POLAR_SERVER=production
POLAR_PRODUCTION_ACCESS_TOKEN=polar_oat_production_token
POLAR_PRODUCTION_WEBHOOK_SECRET=polar_whs_production_secret
POLAR_PRODUCTION_PRO_PRODUCT_ID=production_pro_product_uuid
POLAR_PRODUCTION_MAX_PRODUCT_ID=production_max_product_uuid

# Resend (https://resend.com) — transactional + digest emails
RESEND_API_KEY=your_resend_api_key

# Cron secret — protects /api/cron (Vercel Cron sends it as a Bearer token)
CRON_SECRET=generate_a_long_random_string
